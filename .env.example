# GitHub Credentials
# Generate a Personal Access Token (classic) with 'repo' scope at https://github.com/settings/tokens
GITHUB_TOKEN="ghp_your_personal_access_token_here"
# The repository to clone into /workspace if the directory is empty on startup (format: owner/repo)
GITHUB_REPO="username/repository"

# Git Identity (Used for commits made by Claude inside the container)
GIT_USER_NAME="Your Name"
GIT_USER_EMAIL="your.email@example.com"

# Host System Configuration Paths
# Absolute path to the project directory on your host VPS
PROJECT_PATH="/home/username/projects/my-repo"
# Absolute path to the Claude configuration directory on your host VPS (~/.claude)
CLAUDE_CONFIG_PATH="/home/username/.claude"
# Absolute path to the Claude authentication state JSON file on your host VPS (~/.claude.json)
CLAUDE_JSON_PATH="/home/username/.claude.json"

# Headroom context compression (saves up to 60-95% of tokens by compressing tool outputs/logs)
# Absolute path to the Headroom persistent data directory on your host VPS (~/.headroom)
HEADROOM_CONFIG_PATH="/home/username/.headroom"
# Unique project identifier for stats tracking and cache segmentation in Headroom
HEADROOM_PROJECT_NAME="my-project"
# Port on the host VPS to bind the Headroom proxy to (default: 8787)
HEADROOM_HOST_PORT="8787"
# Docker Compose profiles to load. Set to "headroom" to enable the separate Headroom proxy container, or leave blank to disable.
COMPOSE_PROFILES=""
# Redirect Claude Code's Anthropic API requests to the local Headroom proxy container.
# Set to "http://headroom:8787" if using Headroom, or leave blank to send traffic directly to Anthropic.
# (Automatically includes /p/<project-name> when Headroom is configured via setup.sh)
ANTHROPIC_BASE_URL=""

# --- Session & Identity Persistence Configuration ---
# Persistent session name for Claude Code Remote Control. Defaults to your repository name.
SESSION_NAME="my-project-session"
# UUID associated with your Remote Control session. Reusing this UUID ensures you do
# not need to re-pair remote control terminals across container restarts, but can
# sometimes cause the session to lock up. Leave empty to use a dynamic UUID on each run.
SESSION_UUID="a2345678-1234-1234-1234-1234567890ab"

# --- Permissions Configuration ---
# Permission mode for Claude Code. Options: auto, default, acceptEdits, plan, dontAsk, bypassPermissions.
# Default is 'auto' to use Claude's auto mode.
PERMISSION_MODE="auto"

# --- Host File Permission Mapping (User Identity Adapter) ---
# Running container user ID to match the host system user. Prevents root ownership leaks.
PUID="1000"
# Running container group ID to match the host system group. Prevents root ownership leaks.
PGID="1000"




